# Supabase Postgres connection strings.
# DATABASE_URL: pooled connection via Supavisor, transaction mode (port 6543) — used at runtime by the app/functions.
# DIRECT_URL: direct connection (port 5432) — used only by Prisma Migrate, which needs a non-pooled connection.
# Get both from: Supabase Dashboard -> Project Settings -> Database -> Connection string.

DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
