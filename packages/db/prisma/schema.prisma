// Phase 0 — Identity & Access schema.
// See BLUEPRINT.md §7 for the full multi-phase data model plan.
// Additional domains (products/batches/sales/patients/...) are added in later phases.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (Supavisor, transaction mode) — used at runtime
  directUrl = env("DIRECT_URL") // direct connection — used for migrations only
}

// ---------- Identity & Access ----------

model Organisation {
  id        String             @id @default(uuid())
  name      String
  settings  Json?
  status    OrganisationStatus @default(ACTIVE)
  plan      OrganisationPlan   @default(STARTER)
  createdAt DateTime           @default(now())

  branches   Branch[]
  warehouses Warehouse[]
  users      User[]
  roles      Role[]
  domains    OrganisationDomain[]

  categories              Category[]
  products                Product[]
  stockMovements          StockMovement[]
  customers               Customer[]
  sales                   Sale[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  stockTransfers          StockTransfer[]
  suppliers               Supplier[]
  purchaseOrders          PurchaseOrder[]
  prescriptions           Prescription[]
  orders                  Order[]
  drugRecalls             DrugRecall[]
  adverseReactionReports  AdverseReactionReport[]
  auditLogs               AuditLog[]
  nhisClaims              NhisClaim[]

  @@map("organisations")
}

enum OrganisationStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum OrganisationPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

// Phase 13 SaaS scaffold: maps storefront/admin hostnames to the organisation
// whose public catalogue they should resolve to. This does not add self-service
// signup or billing yet; it replaces Phase 9's manual NEXT_PUBLIC_ORGANISATION_ID
// with a real tenant-resolution path when the deployment is ready.
model OrganisationDomain {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  hostname  String   @unique
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([organisationId, isActive])
  @@map("organisation_domains")
}

model Branch {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  name  String
  code  String
  phone String?
  email String?

  gpsLat          Float?
  gpsLng          Float?
  digitalAddress  String?
  physicalAddress String?
  openingHours    Json?

  pharmacyLicenceNumber String?
  licenceExpiryDate     DateTime?

  superintendentPharmacistUserId String?
  superintendentPharmacist       User?   @relation("BranchSuperintendent", fields: [superintendentPharmacistUserId], references: [id])

  nhisStatus           String?
  deliveryCoverageArea Json?

  defaultWarehouseId String?
  defaultWarehouse   Warehouse? @relation(fields: [defaultWarehouseId], references: [id])

  clinicalCareEnabled Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  userRoles              UserRole[]
  usersWithPrimaryBranch User[]     @relation("UserPrimaryBranch")

  branchStock             BranchStock[]
  stockMovements          StockMovement[]
  tillSessions            TillSession[]
  sales                   Sale[]
  shifts                  Shift[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  transfersFrom           StockTransfer[]          @relation("TransferFromBranch")
  transfersTo             StockTransfer[]          @relation("TransferToBranch")
  purchaseOrders          PurchaseOrder[]
  prescriptions           Prescription[]
  patientVitals           PatientVital[]
  consultations           Consultation[]
  orders                  Order[]
  customersPreferring     Customer[]
  auditLogs               AuditLog[]

  @@unique([organisationId, code])
  @@map("branches")
}

model Warehouse {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  name      String
  location  String?
  isCentral Boolean  @default(false)
  createdAt DateTime @default(now())

  defaultForBranches Branch[]

  @@map("warehouses")
}

model User {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  firebaseUid String   @unique
  name        String
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  primaryBranchId String?
  primaryBranch   Branch? @relation("UserPrimaryBranch", fields: [primaryBranchId], references: [id])

  userRoles              UserRole[]
  superintendentBranches Branch[]   @relation("BranchSuperintendent")

  stockMovementsPerformed StockMovement[] @relation("StockMovementPerformedBy")
  stockMovementsApproved  StockMovement[] @relation("StockMovementApprovedBy")

  tillSessionsAsCashier TillSession[] @relation("TillSessionCashier")
  tillSessionsClosed    TillSession[] @relation("TillSessionClosedBy")
  salesAsCashier        Sale[]        @relation("SaleCashier")

  shifts                    Shift[]
  stockAdjustmentRequested  StockAdjustmentRequest[] @relation("StockAdjustmentRequestedBy")
  stockAdjustmentReviewed   StockAdjustmentRequest[] @relation("StockAdjustmentReviewedBy")
  transfersRequested        StockTransfer[]          @relation("TransferRequestedBy")
  transfersApproved         StockTransfer[]          @relation("TransferApprovedBy")
  purchaseOrdersCreated     PurchaseOrder[]          @relation("PurchaseOrderCreatedBy")
  purchaseOrdersApproved    PurchaseOrder[]          @relation("PurchaseOrderApprovedBy")
  prescriptionsReviewed     Prescription[]           @relation("PrescriptionReviewedBy")
  patientVitalsRecorded     PatientVital[]
  consultationsAsPharmacist Consultation[]
  carePlansCreated          CarePlan[]
  deliveriesAsRider         Delivery[]
  drugRecallsInitiated      DrugRecall[]             @relation("DrugRecallInitiatedBy")
  adverseReactionsReported  AdverseReactionReport[]  @relation("AdverseReactionReportedBy")
  auditLogs                 AuditLog[]

  @@map("users")
}

model Role {
  id             String        @id @default(uuid())
  organisationId String? // null = system default role template, shared across orgs
  organisation   Organisation? @relation(fields: [organisationId], references: [id])

  name            String
  isSystemDefault Boolean  @default(false)
  createdAt       DateTime @default(now())

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([organisationId, name])
  @@map("roles")
}

enum PermissionResource {
  SALES
  PRODUCTS
  STOCK
  PURCHASES
  CUSTOMERS
  SUPPLIERS
  EMPLOYEES
  EXPENSES
  REPORTS
  PRESCRIPTIONS
  PRICING
  TRANSFERS
  RETURNS
  BRANCHES
  SETTINGS
  PATIENTS
  CARE_PLANS
  ORDERS
  DELIVERIES
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  APPROVE
  CANCEL
  DELETE
  EXPORT
}

model Permission {
  id       String             @id @default(uuid())
  resource PermissionResource
  action   PermissionAction

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// The key table: scopes a role assignment to a branch (null = org-wide, e.g. Super Admin).
// A user can hold multiple rows here — e.g. same user_id/branch_id with two different
// role_ids to represent "Branch Manager" + "Superintendent Pharmacist" on one account.
model UserRole {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  roleId   String
  role     Role    @relation(fields: [roleId], references: [id])
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, roleId, branchId])
  @@map("user_roles")
}

// ---------- Product & Inventory (Phase 2) ----------
// Product.preferredSupplierId and Batch.supplierId/purchaseOrderId reference
// the Supplier/PurchaseOrder models added in Phase 6, below.

model Category {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  name             String
  parentCategoryId String?
  parentCategory   Category?  @relation("CategoryToSubcategory", fields: [parentCategoryId], references: [id])
  subcategories    Category[] @relation("CategoryToSubcategory")

  products Product[]

  @@unique([organisationId, name, parentCategoryId])
  @@map("categories")
}

enum PrescriptionClassification {
  OTC
  POM
  RESTRICTED
}

model Product {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  name             String
  genericName      String?
  brandName        String?
  activeIngredient String?
  strength         String?
  dosageForm       String?
  packSize         String?
  manufacturer     String?
  countryOfOrigin  String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  barcode String?
  sku     String?

  fdaRegistrationNumber      String?
  registrationStatus         String?
  registrationExpiry         DateTime?
  prescriptionClassification PrescriptionClassification @default(OTC)
  controlledStatus           String?

  trackBatch        Boolean @default(true)
  trackExpiry       Boolean @default(true)
  minStock          Int?
  maxStock          Int?
  reorderLevel      Int?
  storageConditions String?

  preferredSupplierId String?
  preferredSupplier   Supplier? @relation("ProductPreferredSupplier", fields: [preferredSupplierId], references: [id])

  costPrice          Decimal? @db.Decimal(12, 2)
  wholesalePrice     Decimal? @db.Decimal(12, 2)
  retailPrice        Decimal? @db.Decimal(12, 2)
  minSellingPrice    Decimal? @db.Decimal(12, 2)
  taxConfig          Json?
  maxDiscountPercent Decimal? @db.Decimal(5, 2)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  batches                Batch[]
  saleItems              SaleItem[]
  purchaseOrderItems     PurchaseOrderItem[]
  prescriptionItems      PrescriptionItem[]
  orderItems             OrderItem[]
  adverseReactionReports AdverseReactionReport[]

  @@unique([organisationId, barcode])
  @@map("products")
}

model Batch {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  batchNumber        String
  manufacturingDate  DateTime?
  expiryDate         DateTime?
  receivedDate       DateTime  @default(now())
  costPriceAtReceipt Decimal?  @db.Decimal(12, 2)

  supplierId      String?
  supplier        Supplier?      @relation("BatchSupplier", fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // Denormalized on purpose — checked synchronously in deductStockFefo's hot
  // path on every sale/order, not derived from DrugRecall on every read. The
  // DrugRecall model below is the audit history (reason/who/when); this
  // field is just "is this batch currently blocked from sale."
  recallStatus BatchRecallStatus @default(NONE)

  branchStock             BranchStock[]
  stockMovements          StockMovement[]
  saleItems               SaleItem[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  stockTransferItems      StockTransferItem[]
  orderItems              OrderItem[]
  drugRecalls             DrugRecall[]
  adverseReactionReports  AdverseReactionReport[]

  @@unique([productId, batchNumber])
  @@map("batches")
}

// Cached current balance per branch/batch. Never written directly — only ever
// updated as a side effect of a StockMovement insert, in the same transaction
// (see applyStockMovement in functions/src/inventory/ledger.ts). StockMovement
// is the source of truth; this table exists purely so reads don't have to sum
// the whole ledger every time.
model BranchStock {
  id        String @id @default(uuid())
  branchId  String
  branch    Branch @relation(fields: [branchId], references: [id])
  productId String
  batchId   String
  batch     Batch  @relation(fields: [batchId], references: [id])

  quantityOnHand Int @default(0)

  @@unique([branchId, batchId])
  @@map("branch_stock")
}

enum StockMovementType {
  PURCHASE_RECEIVED
  SALE
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT_DAMAGE
  ADJUSTMENT_EXPIRY
  ADJUSTMENT_LOSS
  ADJUSTMENT_THEFT
  ADJUSTMENT_COUNTING
  ADJUSTMENT_CORRECTION
  RETURN_TO_SUPPLIER
  CUSTOMER_RETURN
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

// The append-only ledger — the single source of truth for all stock quantities
// (BLUEPRINT.md §18-19). Every field here is filled in by applyStockMovement;
// nothing about this table is ever updated or deleted after insert.
model StockMovement {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id])
  productId      String
  batchId        String
  batch          Batch        @relation(fields: [batchId], references: [id])

  movementType    StockMovementType
  quantityDelta   Int
  previousBalance Int
  newBalance      Int

  referenceType String?
  referenceId   String?
  reason        String?

  // Exactly one of these two is set — a movement is either staff-performed
  // (POS sale, receiving, adjustment, transfer) or customer-initiated (an
  // online order placed directly through placeOrder, Phase 9). Both are
  // nullable rather than picking one required FK, because neither User nor
  // Customer is the universal "who did this" answer for every movement type.
  performedByUserId     String?
  performedBy           User?          @relation("StockMovementPerformedBy", fields: [performedByUserId], references: [id])
  performedByCustomerId String?
  performedByCustomer   Customer?      @relation("StockMovementPerformedByCustomer", fields: [performedByCustomerId], references: [id])
  approvedByUserId      String?
  approvedBy            User?          @relation("StockMovementApprovedBy", fields: [approvedByUserId], references: [id])
  approvalStatus        ApprovalStatus @default(NOT_REQUIRED)

  createdAt DateTime @default(now())

  // Every report in Phase 10-11 filters by branch + a date range (or by
  // batch, for recall impact lookups) — these are the two hot paths once
  // this table has real volume.
  @@index([branchId, createdAt])
  @@index([batchId])
  @@map("stock_movements")
}

// ---------- Customers & POS (Phase 3) ----------
// Deliberately minimal for now — just enough for phone-based lookup at the
// counter (BLUEPRINT.md §28-29). Phase 8 (patient care) and Phase 9
// (storefront/loyalty) extend this same table rather than creating a
// separate one, per BLUEPRINT.md §28: "every Patient is a Customer."

// Thresholds are a placeholder policy (see computeLoyaltyTier in
// functions/src/lib/loyalty.ts) — no real usage data exists yet to calibrate
// against, same category of "reasonable default, revisit later" as Phase 4's
// adjustment-sensitivity threshold.
enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model Customer {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  phone     String
  name      String?
  email     String?
  isPatient Boolean  @default(false)
  createdAt DateTime @default(now())

  // Nullable — set by linkCustomerAccount only once this customer registers
  // for the online portal; a phone-only counter customer never gets one.
  firebaseUid       String?     @unique
  loyaltyPoints     Int         @default(0)
  loyaltyTier       LoyaltyTier @default(BRONZE)
  preferredBranchId String?
  preferredBranch   Branch?     @relation(fields: [preferredBranchId], references: [id])
  nhisNumber        String?

  sales                   Sale[]
  prescriptions           Prescription[]
  patientProfile          PatientProfile?
  addresses               CustomerAddress[]
  orders                  Order[]
  stockMovementsPerformed StockMovement[]         @relation("StockMovementPerformedByCustomer")
  adverseReactionReports  AdverseReactionReport[]
  nhisClaims              NhisClaim[]

  @@unique([organisationId, phone])
  @@map("customers")
}

model TillSession {
  id            String @id @default(uuid())
  branchId      String
  branch        Branch @relation(fields: [branchId], references: [id])
  cashierUserId String
  cashier       User   @relation("TillSessionCashier", fields: [cashierUserId], references: [id])

  openingFloat    Decimal  @db.Decimal(12, 2)
  closingExpected Decimal? @db.Decimal(12, 2)
  closingActual   Decimal? @db.Decimal(12, 2)
  variance        Decimal? @db.Decimal(12, 2)

  status   TillSessionStatus @default(OPEN)
  openedAt DateTime          @default(now())
  closedAt DateTime?

  closedByUserId String?
  closedBy       User?   @relation("TillSessionClosedBy", fields: [closedByUserId], references: [id])

  sales Sale[]

  @@map("till_sessions")
}

enum TillSessionStatus {
  OPEN
  CLOSED
}

enum SaleStatus {
  COMPLETED
  VOIDED
  REFUNDED_PARTIAL
  REFUNDED_FULL
  HELD
}

model Sale {
  id             String        @id @default(uuid())
  organisationId String
  organisation   Organisation  @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch        @relation(fields: [branchId], references: [id])
  cashierUserId  String
  cashier        User          @relation("SaleCashier", fields: [cashierUserId], references: [id])
  tillSessionId  String
  tillSession    TillSession   @relation(fields: [tillSessionId], references: [id])
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  prescriptionId String?
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])

  status        SaleStatus @default(COMPLETED)
  subtotal      Decimal    @db.Decimal(12, 2)
  discountTotal Decimal    @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal    @default(0) @db.Decimal(12, 2)
  total         Decimal    @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  items      SaleItem[]
  payments   SalePayment[]
  nhisClaims NhisClaim[]

  @@index([branchId, status, createdAt])
  @@map("sales")
}

// One row per batch actually deducted for a line item — if FEFO splits one
// requested product/quantity across two batches, that's two SaleItem rows.
// The cashier only ever sees/enters product-level quantities; this table
// exists so it lines up 1:1 with the stock_movements it caused.
model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  batchId   String
  batch     Batch   @relation(fields: [batchId], references: [id])

  quantity       Int
  unitPrice      Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal @db.Decimal(12, 2)

  // getProfitabilityReport/getBranchBenchmarking join through batchId to get
  // costPriceAtReceipt; getRecallImpactReport filters by batchId directly.
  @@index([batchId])
  @@map("sale_items")
}

enum PaymentMethod {
  CASH
  MOMO
  CARD
  BANK_TRANSFER
  STORE_CREDIT
  INSURANCE
}

model SalePayment {
  id     String @id @default(uuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  paymentMethod   PaymentMethod
  amount          Decimal       @db.Decimal(12, 2)
  referenceNumber String?

  @@map("sale_payments")
}

// ---------- Branch Manager: shifts & approvals (Phase 4) ----------

model Shift {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  clockInAt  DateTime  @default(now())
  clockOutAt DateTime?

  @@map("shifts")
}

// A sensitive stock adjustment (THEFT/LOSS, or large magnitude) awaiting
// Branch Manager review before it's applied. Deliberately a separate table
// from StockMovement, not a StockMovement with a "pending" status — the
// ledger (StockMovement) only ever records changes that have actually
// happened to branch_stock, atomically via applyStockMovement. A request
// that might still be rejected has no business affecting the balance yet.
model StockAdjustmentRequest {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id])
  productId      String
  batchId        String
  batch          Batch        @relation(fields: [batchId], references: [id])

  quantityDelta Int
  movementType  StockMovementType
  note          String?

  requestedByUserId String
  requestedBy       User           @relation("StockAdjustmentRequestedBy", fields: [requestedByUserId], references: [id])
  status            ApprovalStatus @default(PENDING)
  reviewedByUserId  String?
  reviewedBy        User?          @relation("StockAdjustmentReviewedBy", fields: [reviewedByUserId], references: [id])
  reviewedAt        DateTime?

  createdAt DateTime @default(now())

  @@map("stock_adjustment_requests")
}

// ---------- Inter-Branch Transfers (Phase 5) ----------
// Simplified from the blueprint's full Requested/Approved/Preparing/Dispatched/
// InTransit/PartiallyReceived/Received/Rejected/Cancelled list — PREPARING and
// DISPATCHED are warehouse-picking UI states with no distinct business logic
// in this scaffold, collapsed into the APPROVED -> IN_TRANSIT transition.

enum TransferStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  REJECTED
  CANCELLED
}

model StockTransfer {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  fromBranchId String
  fromBranch   Branch @relation("TransferFromBranch", fields: [fromBranchId], references: [id])
  toBranchId   String
  toBranch     Branch @relation("TransferToBranch", fields: [toBranchId], references: [id])

  status TransferStatus @default(REQUESTED)

  requestedByUserId String
  requestedBy       User    @relation("TransferRequestedBy", fields: [requestedByUserId], references: [id])
  approvedByUserId  String?
  approvedBy        User?   @relation("TransferApprovedBy", fields: [approvedByUserId], references: [id])

  createdAt DateTime @default(now())

  items StockTransferItem[]

  @@map("stock_transfers")
}

// batchId is never reassigned — the same batch record (and its expiry date)
// simply gains a branch_stock row at the destination and loses quantity at
// the source, which is what "batch and expiry data must move with the
// transfer" (BLUEPRINT.md §20) means in a schema where Batch is a product-level
// record, not a branch-owned one.
model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id])
  productId  String
  batchId    String
  batch      Batch         @relation(fields: [batchId], references: [id])

  quantityRequested Int
  quantitySent      Int?
  quantityReceived  Int?

  @@map("stock_transfer_items")
}

// ---------- Procurement & Suppliers (Phase 6) ----------

model Supplier {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  companyName        String
  contactPerson      String?
  phone              String?
  email              String?
  address            String?
  paymentTerms       String?
  avgDeliveryDays    Int?
  outstandingBalance Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  preferredByProducts Product[]       @relation("ProductPreferredSupplier")
  batches             Batch[]         @relation("BatchSupplier")
  purchaseOrders      PurchaseOrder[]

  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

model PurchaseOrder {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id])
  supplierId     String
  supplier       Supplier     @relation(fields: [supplierId], references: [id])

  status PurchaseOrderStatus @default(DRAFT)

  createdByUserId  String
  createdBy        User    @relation("PurchaseOrderCreatedBy", fields: [createdByUserId], references: [id])
  approvedByUserId String?
  approvedBy       User?   @relation("PurchaseOrderApprovedBy", fields: [approvedByUserId], references: [id])

  createdAt DateTime @default(now())

  items   PurchaseOrderItem[]
  batches Batch[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  quantityOrdered  Int
  quantityReceived Int     @default(0)
  unitCost         Decimal @db.Decimal(12, 2)

  @@map("purchase_order_items")
}

// ---------- Prescriptions & Pharmacist Review (Phase 7) ----------

enum PrescriptionStatus {
  RECEIVED
  UNDER_REVIEW
  CLARIFICATION_REQUIRED
  APPROVED
  PARTIALLY_AVAILABLE
  READY_FOR_PAYMENT
  PREPARING
  READY_FOR_COLLECTION
  COMPLETED
  REJECTED
}

enum PrescriptionItemAvailability {
  PENDING
  AVAILABLE
  PARTIALLY_AVAILABLE
  UNAVAILABLE
}

model Prescription {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id])
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])

  uploadedFileUrl String?
  status          PrescriptionStatus @default(RECEIVED)

  reviewedByPharmacistId String?
  reviewedByPharmacist   User?     @relation("PrescriptionReviewedBy", fields: [reviewedByPharmacistId], references: [id])
  reviewedAt             DateTime?

  createdAt DateTime @default(now())

  items  PrescriptionItem[]
  sales  Sale[]
  orders Order[]

  @@map("prescriptions")
}

// productId is null until a pharmacist matches (or substitutes) it during
// review — see reviewPrescription.ts. The pharmacist's choice of a different
// product than requestedText IS the substitution decision (BLUEPRINT.md §13);
// there's no separate "substitution request" entity, since the review action
// itself is already pharmacist-gated and logged via Prescription's
// reviewedByPharmacistId/reviewedAt.
model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  requestedText      String
  quantity           Int
  productId          String?
  product            Product?                     @relation(fields: [productId], references: [id])
  availabilityStatus PrescriptionItemAvailability @default(PENDING)
  note               String?

  @@map("prescription_items")
}

// ---------- Patient Care Module (Phase 8) ----------
// Clinical records are org-wide, not branch-scoped (confirmed product
// decision: continuity of care across branches matters more than branch data
// isolation for this data — see BLUEPRINT.md §5/§6 account directory).
// recordedByBranchId/branchId fields below are for attribution/audit only,
// never used as an access filter — see requirePermissionAnyBranch in
// functions/src/lib/permissions.ts, which every function in this domain uses
// instead of the usual branch-scoped requirePermission.

model PatientProfile {
  id         String   @id @default(uuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  allergies           Json?
  chronicConditions   Json?
  consentClinicalData Boolean   @default(false)
  consentDate         DateTime?
  createdAt           DateTime  @default(now())

  vitals        PatientVital[]
  consultations Consultation[]
  carePlans     CarePlan[]

  @@map("patient_profiles")
}

model PatientVital {
  id               String         @id @default(uuid())
  patientProfileId String
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id])

  recordedAt         DateTime @default(now())
  recordedByBranchId String
  recordedByBranch   Branch   @relation(fields: [recordedByBranchId], references: [id])
  recordedByUserId   String
  recordedByUser     User     @relation(fields: [recordedByUserId], references: [id])

  bpSystolic   Int?
  bpDiastolic  Int?
  glucoseLevel Decimal? @db.Decimal(6, 2)
  weightKg     Decimal? @db.Decimal(6, 2)
  heightCm     Decimal? @db.Decimal(6, 2)
  other        Json?

  @@map("patient_vitals")
}

model Consultation {
  id               String         @id @default(uuid())
  patientProfileId String
  patientProfile   PatientProfile @relation(fields: [patientProfileId], references: [id])
  pharmacistUserId String
  pharmacist       User           @relation(fields: [pharmacistUserId], references: [id])
  branchId         String
  branch           Branch         @relation(fields: [branchId], references: [id])

  consultationDate DateTime @default(now())
  reason           String
  notes            String?
  outcome          String?
  referredToDoctor Boolean  @default(false)

  @@map("consultations")
}

enum CarePlanStatus {
  ACTIVE
  COMPLETED
  DISCONTINUED
}

model CarePlan {
  id                    String         @id @default(uuid())
  patientProfileId      String
  patientProfile        PatientProfile @relation(fields: [patientProfileId], references: [id])
  createdByPharmacistId String
  createdByPharmacist   User           @relation(fields: [createdByPharmacistId], references: [id])

  condition String
  goals     String?
  status    CarePlanStatus @default(ACTIVE)
  createdAt DateTime       @default(now())

  followups CarePlanFollowup[]

  @@map("care_plans")
}

enum FollowupStatus {
  DUE
  COMPLETED
  MISSED
}

model CarePlanFollowup {
  id         String   @id @default(uuid())
  carePlanId String
  carePlan   CarePlan @relation(fields: [carePlanId], references: [id])

  scheduledDate DateTime
  status        FollowupStatus @default(DUE)
  completedAt   DateTime?
  notes         String?

  @@map("care_plan_followups")
}

// ---------- Storefront, Orders & Delivery (Phase 9) ----------
// Customer.firebaseUid is nullable: a Customer can exist purely from a POS
// phone-number lookup (BLUEPRINT.md §29) without ever registering for the
// online portal. Registering later just fills in this field on the same row
// via linkCustomerAccount — never a second Customer record.

model CustomerAddress {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  label       String
  addressText String
  gpsLat      Float?
  gpsLng      Float?
  createdAt   DateTime @default(now())

  orders Order[]

  @@map("customer_addresses")
}

enum FulfilmentType {
  PICKUP
  DELIVERY
}

// Simplified from the blueprint's full New/Confirmed/Prescription Review/
// Picking/Pharmacist Check/Ready/Out for Delivery/Delivered list only in that
// PRESCRIPTION_REVIEW and PHARMACIST_CHECK are collapsed into reusing the
// existing Prescription workflow (Phase 7) rather than duplicating pharmacist
// sign-off as separate order-status bookkeeping — an order's prescriptionId
// links to a Prescription whose own status already tracks that review.
enum OrderStatus {
  NEW
  CONFIRMED
  PICKING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model Order {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id])
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])

  status            OrderStatus      @default(NEW)
  fulfilmentType    FulfilmentType
  deliveryAddressId String?
  deliveryAddress   CustomerAddress? @relation(fields: [deliveryAddressId], references: [id])
  prescriptionId    String?
  prescription      Prescription?    @relation(fields: [prescriptionId], references: [id])

  subtotal      Decimal @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @db.Decimal(12, 2)
  total         Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  items    OrderItem[]
  payments OrderPayment[]
  delivery Delivery?

  @@index([branchId, status, createdAt])
  @@map("orders")
}

// One row per batch actually deducted, same reasoning as SaleItem (Phase 3) —
// FEFO deduction at order placement (see Decisions in the Phase 9 build log)
// may split one requested product/quantity across batches.
model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  batchId   String
  batch     Batch   @relation(fields: [batchId], references: [id])

  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  @@map("order_items")
}

enum OrderPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  PAYSTACK
}

// Provider fields are intentionally generic enough for Paystack now and other
// Ghana-ready gateways later; the Order remains the source of truth, while the
// gateway is an authorization/settlement rail.
model OrderPayment {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  paymentMethod            PaymentMethod
  amount                   Decimal            @db.Decimal(12, 2)
  status                   OrderPaymentStatus @default(PENDING)
  provider                 PaymentProvider    @default(MANUAL)
  providerReference        String?
  providerAccessCode       String?
  providerAuthorizationUrl String?
  providerStatus           String?
  providerResponse         Json?
  paidAt                   DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@unique([provider, providerReference])
  @@map("order_payments")
}

enum DeliveryStatus {
  UNASSIGNED
  ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

model Delivery {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  riderId String?
  rider   User?          @relation(fields: [riderId], references: [id])
  status  DeliveryStatus @default(UNASSIGNED)

  assignedAt  DateTime?
  deliveredAt DateTime?

  @@map("deliveries")
}

// ---------- Fraud Detection, Audit & Compliance (Phase 11) ----------

enum BatchRecallStatus {
  NONE
  RECALLED
  RESOLVED
}

enum RecallStatus {
  ACTIVE
  RESOLVED
}

// BLUEPRINT.md §42: block further sale, identify affected customers, notify
// branches. "Block further sale" is Batch.recallStatus checked in
// deductStockFefo; "identify affected customers" is answered by querying
// SaleItem/OrderItem for this batchId (no separate denormalized list needed —
// the existing sale/order records already are that list). "Notify branches"
// isn't built — no notification delivery mechanism exists yet in this
// project (same gap as Phase 1's invite emails), so this only makes the
// recall visible to anyone who queries it, not push-notified.
model DrugRecall {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  batchId        String
  batch          Batch        @relation(fields: [batchId], references: [id])

  reason            String
  status            RecallStatus @default(ACTIVE)
  initiatedByUserId String
  initiatedBy       User         @relation("DrugRecallInitiatedBy", fields: [initiatedByUserId], references: [id])
  resolvedAt        DateTime?

  createdAt DateTime @default(now())

  @@map("drug_recalls")
}

// BLUEPRINT.md §43 — captured for future structured regulatory reporting,
// not submitted anywhere automatically (no regulator API exists to submit to).
model AdverseReactionReport {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  batchId        String?
  batch          Batch?       @relation(fields: [batchId], references: [id])
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])

  reactionDescription String
  dateOfReaction      DateTime?
  outcome             String?
  reportedByUserId    String
  reportedBy          User      @relation("AdverseReactionReportedBy", fields: [reportedByUserId], references: [id])
  createdAt           DateTime  @default(now())

  @@map("adverse_reaction_reports")
}

// A general-purpose log for sensitive actions BLUEPRINT.md §53 calls out
// specifically (price changes, role changes, branch deactivation, adjustment
// approvals, recalls) — NOT a retrofit of every one of this project's ~70
// Cloud Functions. See the Phase 11 build log for which actions call
// recordAuditLog and why those were chosen over an exhaustive retrofit.
model AuditLog {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])

  action       String
  resourceType String
  resourceId   String?
  oldValue     Json?
  newValue     Json?
  createdAt    DateTime @default(now())

  @@map("audit_log")
}

enum NhisClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// BLUEPRINT.md §44 — explicitly "scaffolding" for future e-claims
// integration, not a real submission pipeline. No NHIS API exists to submit
// to or validate against; this only records the claim's existence and lets
// status be tracked manually once an integration is chosen.
model NhisClaim {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])
  saleId         String?
  sale           Sale?        @relation(fields: [saleId], references: [id])

  nhisNumber      String
  status          NhisClaimStatus @default(DRAFT)
  rejectionReason String?
  submittedAt     DateTime?
  createdAt       DateTime        @default(now())

  @@map("nhis_claims")
}
