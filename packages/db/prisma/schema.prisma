// Phase 0 — Identity & Access schema.
// See BLUEPRINT.md §7 for the full multi-phase data model plan.
// Additional domains (products/batches/sales/patients/...) are added in later phases.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (Supavisor, transaction mode) — used at runtime
  directUrl = env("DIRECT_URL")   // direct connection — used for migrations only
}

// ---------- Identity & Access ----------

model Organisation {
  id        String   @id @default(uuid())
  name      String
  settings  Json?
  createdAt DateTime @default(now())

  branches   Branch[]
  warehouses Warehouse[]
  users      User[]
  roles      Role[]

  categories     Category[]
  products       Product[]
  stockMovements StockMovement[]
  customers      Customer[]
  sales          Sale[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  stockTransfers StockTransfer[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]

  @@map("organisations")
}

model Branch {
  id           String  @id @default(uuid())
  organisationId String
  organisation Organisation @relation(fields: [organisationId], references: [id])

  name    String
  code    String
  phone   String?
  email   String?

  gpsLat  Float?
  gpsLng  Float?
  digitalAddress  String?
  physicalAddress String?
  openingHours    Json?

  pharmacyLicenceNumber String?
  licenceExpiryDate     DateTime?

  superintendentPharmacistUserId String?
  superintendentPharmacist       User?   @relation("BranchSuperintendent", fields: [superintendentPharmacistUserId], references: [id])

  nhisStatus            String?
  deliveryCoverageArea  Json?

  defaultWarehouseId String?
  defaultWarehouse   Warehouse? @relation(fields: [defaultWarehouseId], references: [id])

  clinicalCareEnabled Boolean @default(false)
  isActive            Boolean @default(true)
  createdAt           DateTime @default(now())

  userRoles UserRole[]
  usersWithPrimaryBranch User[] @relation("UserPrimaryBranch")

  branchStock    BranchStock[]
  stockMovements StockMovement[]
  tillSessions   TillSession[]
  sales          Sale[]
  shifts         Shift[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  transfersFrom  StockTransfer[] @relation("TransferFromBranch")
  transfersTo    StockTransfer[] @relation("TransferToBranch")
  purchaseOrders PurchaseOrder[]

  @@unique([organisationId, code])
  @@map("branches")
}

model Warehouse {
  id             String  @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  name      String
  location  String?
  isCentral Boolean @default(false)
  createdAt DateTime @default(now())

  defaultForBranches Branch[]

  @@map("warehouses")
}

model User {
  id             String  @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  firebaseUid String  @unique
  name        String
  phone       String?
  email       String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  primaryBranchId String?
  primaryBranch   Branch? @relation("UserPrimaryBranch", fields: [primaryBranchId], references: [id])

  userRoles              UserRole[]
  superintendentBranches Branch[] @relation("BranchSuperintendent")

  stockMovementsPerformed StockMovement[] @relation("StockMovementPerformedBy")
  stockMovementsApproved  StockMovement[] @relation("StockMovementApprovedBy")

  tillSessionsAsCashier TillSession[] @relation("TillSessionCashier")
  tillSessionsClosed    TillSession[] @relation("TillSessionClosedBy")
  salesAsCashier        Sale[]        @relation("SaleCashier")

  shifts                     Shift[]
  stockAdjustmentRequested   StockAdjustmentRequest[] @relation("StockAdjustmentRequestedBy")
  stockAdjustmentReviewed    StockAdjustmentRequest[] @relation("StockAdjustmentReviewedBy")
  transfersRequested         StockTransfer[] @relation("TransferRequestedBy")
  transfersApproved          StockTransfer[] @relation("TransferApprovedBy")
  purchaseOrdersCreated      PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  purchaseOrdersApproved     PurchaseOrder[] @relation("PurchaseOrderApprovedBy")

  @@map("users")
}

model Role {
  id             String  @id @default(uuid())
  organisationId String? // null = system default role template, shared across orgs
  organisation   Organisation? @relation(fields: [organisationId], references: [id])

  name            String
  isSystemDefault Boolean @default(false)
  createdAt       DateTime @default(now())

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([organisationId, name])
  @@map("roles")
}

enum PermissionResource {
  SALES
  PRODUCTS
  STOCK
  PURCHASES
  CUSTOMERS
  SUPPLIERS
  EMPLOYEES
  EXPENSES
  REPORTS
  PRESCRIPTIONS
  PRICING
  TRANSFERS
  RETURNS
  BRANCHES
  SETTINGS
  PATIENTS
  CARE_PLANS
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  APPROVE
  CANCEL
  DELETE
  EXPORT
}

model Permission {
  id       String            @id @default(uuid())
  resource PermissionResource
  action   PermissionAction

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// The key table: scopes a role assignment to a branch (null = org-wide, e.g. Super Admin).
// A user can hold multiple rows here — e.g. same user_id/branch_id with two different
// role_ids to represent "Branch Manager" + "Superintendent Pharmacist" on one account.
model UserRole {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  roleId   String
  role     Role    @relation(fields: [roleId], references: [id])
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, roleId, branchId])
  @@map("user_roles")
}

// ---------- Product & Inventory (Phase 2) ----------
// Product.preferredSupplierId and Batch.supplierId/purchaseOrderId reference
// the Supplier/PurchaseOrder models added in Phase 6, below.

model Category {
  id             String  @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  name             String
  parentCategoryId String?
  parentCategory   Category?  @relation("CategoryToSubcategory", fields: [parentCategoryId], references: [id])
  subcategories    Category[] @relation("CategoryToSubcategory")

  products Product[]

  @@unique([organisationId, name, parentCategoryId])
  @@map("categories")
}

enum PrescriptionClassification {
  OTC
  POM
  RESTRICTED
}

model Product {
  id             String  @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  name             String
  genericName      String?
  brandName        String?
  activeIngredient String?
  strength         String?
  dosageForm       String?
  packSize         String?
  manufacturer     String?
  countryOfOrigin  String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  barcode String?
  sku     String?

  fdaRegistrationNumber     String?
  registrationStatus        String?
  registrationExpiry        DateTime?
  prescriptionClassification PrescriptionClassification @default(OTC)
  controlledStatus          String?

  trackBatch     Boolean @default(true)
  trackExpiry    Boolean @default(true)
  minStock       Int?
  maxStock       Int?
  reorderLevel   Int?
  storageConditions String?

  preferredSupplierId String?
  preferredSupplier   Supplier? @relation("ProductPreferredSupplier", fields: [preferredSupplierId], references: [id])

  costPrice         Decimal? @db.Decimal(12, 2)
  wholesalePrice    Decimal? @db.Decimal(12, 2)
  retailPrice       Decimal? @db.Decimal(12, 2)
  minSellingPrice   Decimal? @db.Decimal(12, 2)
  taxConfig         Json?
  maxDiscountPercent Decimal? @db.Decimal(5, 2)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  batches   Batch[]
  saleItems SaleItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([organisationId, barcode])
  @@map("products")
}

model Batch {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  batchNumber       String
  manufacturingDate DateTime?
  expiryDate        DateTime?
  receivedDate      DateTime  @default(now())
  costPriceAtReceipt Decimal? @db.Decimal(12, 2)

  supplierId String?
  supplier   Supplier? @relation("BatchSupplier", fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  branchStock    BranchStock[]
  stockMovements StockMovement[]
  saleItems      SaleItem[]
  stockAdjustmentRequests StockAdjustmentRequest[]
  stockTransferItems StockTransferItem[]

  @@unique([productId, batchNumber])
  @@map("batches")
}

// Cached current balance per branch/batch. Never written directly — only ever
// updated as a side effect of a StockMovement insert, in the same transaction
// (see applyStockMovement in functions/src/inventory/ledger.ts). StockMovement
// is the source of truth; this table exists purely so reads don't have to sum
// the whole ledger every time.
model BranchStock {
  id        String  @id @default(uuid())
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id])
  productId String
  batchId   String
  batch     Batch   @relation(fields: [batchId], references: [id])

  quantityOnHand Int @default(0)

  @@unique([branchId, batchId])
  @@map("branch_stock")
}

enum StockMovementType {
  PURCHASE_RECEIVED
  SALE
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT_DAMAGE
  ADJUSTMENT_EXPIRY
  ADJUSTMENT_LOSS
  ADJUSTMENT_THEFT
  ADJUSTMENT_COUNTING
  ADJUSTMENT_CORRECTION
  RETURN_TO_SUPPLIER
  CUSTOMER_RETURN
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

// The append-only ledger — the single source of truth for all stock quantities
// (BLUEPRINT.md §18-19). Every field here is filled in by applyStockMovement;
// nothing about this table is ever updated or deleted after insert.
model StockMovement {
  id             String @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch @relation(fields: [branchId], references: [id])
  productId      String
  batchId        String
  batch          Batch  @relation(fields: [batchId], references: [id])

  movementType     StockMovementType
  quantityDelta    Int
  previousBalance  Int
  newBalance       Int

  referenceType String?
  referenceId   String?
  reason        String?

  performedByUserId String
  performedBy       User    @relation("StockMovementPerformedBy", fields: [performedByUserId], references: [id])
  approvedByUserId  String?
  approvedBy        User?   @relation("StockMovementApprovedBy", fields: [approvedByUserId], references: [id])
  approvalStatus    ApprovalStatus @default(NOT_REQUIRED)

  createdAt DateTime @default(now())

  @@map("stock_movements")
}

// ---------- Customers & POS (Phase 3) ----------
// Deliberately minimal for now — just enough for phone-based lookup at the
// counter (BLUEPRINT.md §28-29). Phase 8 (patient care) and Phase 9
// (storefront/loyalty) extend this same table rather than creating a
// separate one, per BLUEPRINT.md §28: "every Patient is a Customer."

model Customer {
  id             String  @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  phone     String
  name      String?
  email     String?
  isPatient Boolean  @default(false)
  createdAt DateTime @default(now())

  sales Sale[]

  @@unique([organisationId, phone])
  @@map("customers")
}

model TillSession {
  id            String  @id @default(uuid())
  branchId      String
  branch        Branch  @relation(fields: [branchId], references: [id])
  cashierUserId String
  cashier       User    @relation("TillSessionCashier", fields: [cashierUserId], references: [id])

  openingFloat   Decimal  @db.Decimal(12, 2)
  closingExpected Decimal? @db.Decimal(12, 2)
  closingActual   Decimal? @db.Decimal(12, 2)
  variance        Decimal? @db.Decimal(12, 2)

  status   TillSessionStatus @default(OPEN)
  openedAt DateTime          @default(now())
  closedAt DateTime?

  closedByUserId String?
  closedBy       User?   @relation("TillSessionClosedBy", fields: [closedByUserId], references: [id])

  sales Sale[]

  @@map("till_sessions")
}

enum TillSessionStatus {
  OPEN
  CLOSED
}

enum SaleStatus {
  COMPLETED
  VOIDED
  REFUNDED_PARTIAL
  REFUNDED_FULL
  HELD
}

model Sale {
  id             String  @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch  @relation(fields: [branchId], references: [id])
  cashierUserId  String
  cashier        User    @relation("SaleCashier", fields: [cashierUserId], references: [id])
  tillSessionId  String
  tillSession    TillSession @relation(fields: [tillSessionId], references: [id])
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])

  status        SaleStatus @default(COMPLETED)
  subtotal      Decimal    @db.Decimal(12, 2)
  discountTotal Decimal    @db.Decimal(12, 2) @default(0)
  taxTotal      Decimal    @db.Decimal(12, 2) @default(0)
  total         Decimal    @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  items    SaleItem[]
  payments SalePayment[]

  @@map("sales")
}

// One row per batch actually deducted for a line item — if FEFO splits one
// requested product/quantity across two batches, that's two SaleItem rows.
// The cashier only ever sees/enters product-level quantities; this table
// exists so it lines up 1:1 with the stock_movements it caused.
model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  batchId   String
  batch     Batch   @relation(fields: [batchId], references: [id])

  quantity        Int
  unitPrice       Decimal @db.Decimal(12, 2)
  discountAmount  Decimal @db.Decimal(12, 2) @default(0)
  lineTotal       Decimal @db.Decimal(12, 2)

  @@map("sale_items")
}

enum PaymentMethod {
  CASH
  MOMO
  CARD
  BANK_TRANSFER
  STORE_CREDIT
  INSURANCE
}

model SalePayment {
  id     String @id @default(uuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  paymentMethod   PaymentMethod
  amount          Decimal @db.Decimal(12, 2)
  referenceNumber String?

  @@map("sale_payments")
}

// ---------- Branch Manager: shifts & approvals (Phase 4) ----------

model Shift {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  branchId String
  branch   Branch  @relation(fields: [branchId], references: [id])

  clockInAt  DateTime  @default(now())
  clockOutAt DateTime?

  @@map("shifts")
}

// A sensitive stock adjustment (THEFT/LOSS, or large magnitude) awaiting
// Branch Manager review before it's applied. Deliberately a separate table
// from StockMovement, not a StockMovement with a "pending" status — the
// ledger (StockMovement) only ever records changes that have actually
// happened to branch_stock, atomically via applyStockMovement. A request
// that might still be rejected has no business affecting the balance yet.
model StockAdjustmentRequest {
  id             String @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch @relation(fields: [branchId], references: [id])
  productId      String
  batchId        String
  batch          Batch  @relation(fields: [batchId], references: [id])

  quantityDelta Int
  movementType  StockMovementType
  note          String?

  requestedByUserId String
  requestedBy       User   @relation("StockAdjustmentRequestedBy", fields: [requestedByUserId], references: [id])
  status            ApprovalStatus @default(PENDING)
  reviewedByUserId  String?
  reviewedBy        User?  @relation("StockAdjustmentReviewedBy", fields: [reviewedByUserId], references: [id])
  reviewedAt        DateTime?

  createdAt DateTime @default(now())

  @@map("stock_adjustment_requests")
}

// ---------- Inter-Branch Transfers (Phase 5) ----------
// Simplified from the blueprint's full Requested/Approved/Preparing/Dispatched/
// InTransit/PartiallyReceived/Received/Rejected/Cancelled list — PREPARING and
// DISPATCHED are warehouse-picking UI states with no distinct business logic
// in this scaffold, collapsed into the APPROVED -> IN_TRANSIT transition.

enum TransferStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  REJECTED
  CANCELLED
}

model StockTransfer {
  id             String  @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  fromBranchId String
  fromBranch   Branch @relation("TransferFromBranch", fields: [fromBranchId], references: [id])
  toBranchId   String
  toBranch     Branch @relation("TransferToBranch", fields: [toBranchId], references: [id])

  status TransferStatus @default(REQUESTED)

  requestedByUserId String
  requestedBy       User    @relation("TransferRequestedBy", fields: [requestedByUserId], references: [id])
  approvedByUserId  String?
  approvedBy        User?   @relation("TransferApprovedBy", fields: [approvedByUserId], references: [id])

  createdAt DateTime @default(now())

  items StockTransferItem[]

  @@map("stock_transfers")
}

// batchId is never reassigned — the same batch record (and its expiry date)
// simply gains a branch_stock row at the destination and loses quantity at
// the source, which is what "batch and expiry data must move with the
// transfer" (BLUEPRINT.md §20) means in a schema where Batch is a product-level
// record, not a branch-owned one.
model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id])
  productId  String
  batchId    String
  batch      Batch         @relation(fields: [batchId], references: [id])

  quantityRequested Int
  quantitySent      Int?
  quantityReceived  Int?

  @@map("stock_transfer_items")
}

// ---------- Procurement & Suppliers (Phase 6) ----------

model Supplier {
  id             String  @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  companyName       String
  contactPerson     String?
  phone             String?
  email             String?
  address           String?
  paymentTerms      String?
  avgDeliveryDays   Int?
  outstandingBalance Decimal @db.Decimal(12, 2) @default(0)

  createdAt DateTime @default(now())

  preferredByProducts Product[] @relation("ProductPreferredSupplier")
  batches             Batch[]   @relation("BatchSupplier")
  purchaseOrders      PurchaseOrder[]

  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

model PurchaseOrder {
  id             String  @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  branchId       String
  branch         Branch  @relation(fields: [branchId], references: [id])
  supplierId     String
  supplier       Supplier @relation(fields: [supplierId], references: [id])

  status PurchaseOrderStatus @default(DRAFT)

  createdByUserId  String
  createdBy        User    @relation("PurchaseOrderCreatedBy", fields: [createdByUserId], references: [id])
  approvedByUserId String?
  approvedBy       User?   @relation("PurchaseOrderApprovedBy", fields: [approvedByUserId], references: [id])

  createdAt DateTime @default(now())

  items   PurchaseOrderItem[]
  batches Batch[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])

  quantityOrdered  Int
  quantityReceived Int     @default(0)
  unitCost         Decimal @db.Decimal(12, 2)

  @@map("purchase_order_items")
}
