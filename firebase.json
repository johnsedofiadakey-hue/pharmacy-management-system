{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "predeploy": [
        "pnpm --filter @pharmacy-os/db generate",
        "pnpm --filter @pharmacy-os/db build",
        "npm --prefix functions run vendor-db",
        "pnpm install",
        "npm --prefix functions run build"
      ]
    }
  ],
  "hosting": {
    "source": "apps/web"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true },
    "singleProjectMode": true
  }
}
