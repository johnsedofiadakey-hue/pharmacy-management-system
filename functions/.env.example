# Runtime database connection for deployed Firebase Functions.
# Use the Supabase pooled transaction-mode URL, not DIRECT_URL.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Paystack secret key from Paystack Dashboard -> Settings -> API Keys & Webhooks.
# Use test secret key while live-testing, then switch to live key only after real checkout is approved.
PAYSTACK_SECRET_KEY="sk_test_xxx"
